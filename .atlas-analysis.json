  "keyFeatures": [
    "Hardware-accelerated cryptography via Intel QuickAssist Technology",
    "Optimized software acceleration using Intel instruction sets",
    "Support for RSA, ECDH, ECDSA, AES-GCM, ChaCha20-Poly1305, and more",
    "Asynchronous and pipelined operations for high throughput",
    "OpenSSL 3.0 provider support and FIPS 140-3 compliance",
    "Dual-mode operation with QAT_HW and QAT_SW co-existence"
  ],
  "publicApiSurface": [
    "qatengine (OpenSSL Engine)",
    "qatprovider (OpenSSL 3.0 Provider)",
    "QAT_HW acceleration APIs (RSA, DH, DSA, ECDH, ECDSA, ECX, AES-GCM, AES-CCM, ChaCha20-Poly1305, PRF, HKDF, SHA3, SM2, SM3, SM4)",
    "QAT_SW acceleration APIs (RSA, ECDH, ECDSA, ECX, AES-GCM, SM2, SM3, SM4)",
    "Engine control commands (ENABLE_EXTERNAL_POLLING, POLL, SET_INSTANCE_FOR_THREAD, INIT_ENGINE, etc.)",
    "Memory management APIs (qae_mem utilities)",
    "Asynchronous job handling",
    "Software fallback mechanisms",
    "KPT (Key Protection Technology) support",
    "BoringSSL integration APIs"
